@article{frazier_sausage_1978,
	title = {The sausage machine: {A} new two-stage parsing model},
	volume = {6},
	issn = {1873-7838(Electronic),0010-0277(Print)},
	shorttitle = {The sausage machine},
	doi = {10.1016/0010-0277(78)90002-1},
	abstract = {Proposes that the human sentence parsing device assigns phrase structure to word strings in 2 steps. The 1st stage parser assigns lexical and phrasal nodes to substrings of roughly 6 words. The 2nd stage parser then adds higher nodes to link these phrasal packages into a complete phrase marker. This model of the parser is compared with augmented transition network models, and with the 2-stage models of J. Kimball (1973) and J. A. Fodor et al (1974). (French summary) (24 ref) (PsycINFO Database Record (c) 2016 APA, all rights reserved)},
